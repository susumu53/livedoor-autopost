# DMM/FANZA API
DMM_API_ID=your_api_id
DMM_AFFILIATE_ID=your_affiliate_id

# Livedoor Blog AtomPub
LIVEDOOR_ID=your_livedoor_id
LIVEDOOR_BLOG_ID=your_blog_id
LIVEDOOR_API_KEY=your_api_key

# Amazon PA-API (Optional)
AMAZON_ACCESS_KEY=your_access_key
AMAZON_SECRET_KEY=your_secret_key
AMAZON_PARTNER_TAG=your_partner_tag

# WordPress API (Optional, for Beauty Index synchronization)
WP_URL=your_wp_url
WP_USERNAME=your_wp_username
WP_APP_PASSWORD=your_app_password
